{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.2,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": [
      "zh"
    ],
    "analysis_concurrency": 3,
    "enrichment_concurrency": 2
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": false
    },
    "rss": [],
    "reddit": {
      "enabled": true,
      "fetch_comments": 3,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 10,
          "category": "reddit-hot"
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 10,
          "category": "reddit-hot"
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 10,
          "category": "reddit-hot"
        },
        {
          "subreddit": "programming",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 10,
          "category": "reddit-hot"
        },
        {
          "subreddit": "technology",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 10,
          "category": "reddit-hot"
        },
        {
          "subreddit": "opensource",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 10,
          "category": "reddit-hot"
        }
      ],
      "users": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All"
      ],
      "keywords": [
        "ai",
        "llm",
        "agent",
        "developer",
        "devtool",
        "coding",
        "machine learning",
        "code",
        "cli",
        "tool",
        "framework",
        "sdk",
        "api"
      ],
      "min_stars": 1,
      "max_items": 10,
      "category": "github-hot"
    },
    "twitter": {
      "enabled": true,
      "users": [
        "OpenAI",
        "AnthropicAI",
        "GoogleDeepMind",
        "huggingface",
        "karpathy"
      ],
      "fetch_limit": 100,
      "category": "x-hot",
      "fetch_reply_text": false,
      "max_replies_per_tweet": 0,
      "max_tweets_to_expand": 0,
      "reply_min_likes": 0,
      "apify_token_env": "APIFY_TOKEN"
    }
  },
  "filtering": {
    "ai_score_threshold": 0.0,
    "time_window_hours": 24,
    "max_items": 25,
    "category_groups": {
      "reddit": {
        "name": "Reddit ??",
        "limit": 5,
        "categories": [
          "reddit-hot"
        ]
      },
      "github": {
        "name": "GitHub ????",
        "limit": 10,
        "categories": [
          "github-hot"
        ]
      },
      "twitter": {
        "name": "X ??",
        "limit": 10,
        "categories": [
          "x-hot"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 1
  },
  "webhook": {
    "enabled": false
  }
}
