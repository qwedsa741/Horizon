{
    "version":  "1.0",
    "ai":  {
               "provider":  "deepseek",
               "model":  "deepseek-chat",
               "base_url":  "https://api.deepseek.com",
               "api_key_env":  "DEEPSEEK_API_KEY",
               "temperature":  0.2,
               "max_tokens":  8192,
               "throttle_sec":  1,
               "languages":  [
                                 "zh"
                             ],
               "analysis_concurrency":  3,
               "enrichment_concurrency":  2
           },
    "sources":  {
                    "github":  [
                                   {
                                       "type":  "repo_releases",
                                       "owner":  "openai",
                                       "repo":  "openai-python",
                                       "enabled":  true
                                   },
                                   {
                                       "type":  "repo_releases",
                                       "owner":  "huggingface",
                                       "repo":  "transformers",
                                       "enabled":  true
                                   },
                                   {
                                       "type":  "repo_releases",
                                       "owner":  "vllm-project",
                                       "repo":  "vllm",
                                       "enabled":  true
                                   },
                                   {
                                       "type":  "repo_releases",
                                       "owner":  "ollama",
                                       "repo":  "ollama",
                                       "enabled":  true
                                   }
                               ],
                    "hackernews":  {
                                       "enabled":  true,
                                       "fetch_top_stories":  30,
                                       "min_score":  100
                                   },
                    "rss":  [
                                {
                                    "name":  "OpenAI News",
                                    "url":  "https://openai.com/news/rss.xml",
                                    "enabled":  true,
                                    "category":  "ai-labs"
                                },
                                {
                                    "name":  "Hugging Face Blog",
                                    "url":  "https://huggingface.co/blog/feed.xml",
                                    "enabled":  true,
                                    "category":  "open-source-ai"
                                },
                                {
                                    "name":  "Simon Willison",
                                    "url":  "https://simonwillison.net/atom/everything/",
                                    "enabled":  true,
                                    "category":  "ai-tools"
                                },
                                {
                                    "name":  "Google AI Blog",
                                    "url":  "https://blog.google/technology/ai/rss/",
                                    "enabled":  true,
                                    "category":  "ai-labs"
                                }
                            ],
                    "reddit":  {
                                   "enabled":  true,
                                   "subreddits":  [
                                                      {
                                                          "subreddit":  "MachineLearning",
                                                          "enabled":  true,
                                                          "sort":  "hot",
                                                          "time_filter":  "day",
                                                          "fetch_limit":  15,
                                                          "min_score":  40
                                                      },
                                                      {
                                                          "subreddit":  "LocalLLaMA",
                                                          "enabled":  true,
                                                          "sort":  "hot",
                                                          "time_filter":  "day",
                                                          "fetch_limit":  15,
                                                          "min_score":  40
                                                      }
                                                  ],
                                   "users":  [

                                             ],
                                   "fetch_comments":  5
                               }
                },
    "filtering":  {
                      "ai_score_threshold":  7.0,
                      "time_window_hours":  24,
                      "max_items":  15,
                      "category_groups":  {
                                              "ai_labs":  {
                                                              "limit":  5,
                                                              "categories":  [
                                                                                 "ai-labs"
                                                                             ]
                                                          },
                                              "open_source":  {
                                                                  "limit":  5,
                                                                  "categories":  [
                                                                                     "open-source-ai",
                                                                                     "ai-tools"
                                                                                 ]
                                                              }
                                          },
                      "default_group":  "other",
                      "default_group_limit":  5
                  },
    "webhook":  {
                    "enabled":  false
                }
}